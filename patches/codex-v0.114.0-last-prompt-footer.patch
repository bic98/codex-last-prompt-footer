+#[tokio::test]
+async fn status_line_appends_last_submitted_prompt_preview() {
+    let (mut chat, _rx, mut op_rx) = make_chatwidget_manual(Some("gpt-5.4")).await;
+    chat.thread_id = Some(ThreadId::new());
+    chat.config.tui_status_line = Some(vec!["model-name".to_string()]);
+    chat.refresh_status_line();
+    assert_eq!(status_line_text(&chat), Some("gpt-5.4".to_string()));
+
+    chat.submit_user_message_with_mode(
+        "check\nthis    footer prompt preview".to_string(),
+        chat.active_collaboration_mask
+            .clone()
+            .expect("expected collaboration mask"),
+    );
+
+    assert_matches!(
+        next_submit_op(&mut op_rx),
+        Op::UserTurn {
+            collaboration_mode: Some(_),
+            ..
+        }
+    );
+    assert_eq!(
+        status_line_text(&chat),
+        Some("gpt-5.4 · Q: check this footer prompt preview".to_string())
+    );
+}
